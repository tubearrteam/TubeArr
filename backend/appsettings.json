{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "TubeArr.Backend.DownloadQueueProcessor": "Warning",
        "TubeArr.Backend.Plex": "Debug",
        "TubeArr.Backend.Plex.PlexProviderLog": "Debug"
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Warning"
    }
  },
  "ConnectionStrings": {
    "TubeArr": "Data Source=TubeArr.db"
  },
  "YouTube": {
    "ApiKey": ""
  },
  "AllowedHosts": "*",
  "TubeArr": {
    "UpdateCheckUrl": "https://api.github.com/repos/tubearrteam/TubeArr/releases?per_page=20",
    "DownloadHistoryRetentionDays": 90
  },
  "Plex": {
    "HttpProbeLogging": false
  }
}
