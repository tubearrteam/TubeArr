    <ImplicitUsings>enable</ImplicitUsings>
    <Version>0.8.5</Version>
  </PropertyGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="TubeArr.Backend.Tests" />
  </ItemGroup>

  <ItemGroup>
